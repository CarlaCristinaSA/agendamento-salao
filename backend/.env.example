# ===================================
# BANCO DE DADOS
# ===================================
DATABASE_URL=postgresql://usuario:senha@localhost:5432/salon_agendamento

# ===================================
# SERVIDOR
# ===================================
PORT=3000
NODE_ENV=development

# ===================================
# JWT
# ===================================
JWT_SECRET=sua_chave_secreta_muito_segura_aqui
JWT_EXPIRES_IN=8h

# ===================================
# E-MAIL (SMTP)
# ===================================
SMTP_HOST=smtp.exemplo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seu_email@exemplo.com
SMTP_PASS=sua_senha_de_email
EMAIL_FROM=nao-responda@salao.com
EMAIL_FROM_NAME=Salão de Beleza

# ===================================
# CONFIGURAÇÕES DO SALÃO
# ===================================
SALON_NAME=Salão de Beleza

# Fuso horário usado para classificar agendamentos como passados/futuros
# (histórico do cliente) e para a regra de cancelamento de 24h (RN-010).
SALON_TIMEZONE=America/Fortaleza

# E-mail que recebe a notificação quando um CLIENTE cancela um agendamento
# pela área logada (HU-007). Se ausente, o sistema notifica todos os
# usuários com papel "admin" cadastrados no banco.
ADMIN_NOTIFICATION_EMAIL=admin@salao.com

# ===================================
# RECUPERAÇÃO DE SENHA
# ===================================
# Validade (em minutos) do código de 6 dígitos enviado por e-mail.
PASSWORD_RESET_CODE_TTL_MINUTES=15

# Número máximo de tentativas de código antes de invalidá-lo.
PASSWORD_RESET_MAX_ATTEMPTS=5
